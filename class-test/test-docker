FROM node:20 AS builder
WORKDIR /app
COPY package.json ./
RUN npm install

FROM node:18
WORKDIR /app
COPY --from=builder /app/node_modules ./node_modules
COPY server.js ./
COPY package.json ./

RUN groupadd appgroup && \
    useradd -r -g appgroup appuser
USER appuser
EXPOSE 3000
CMD ["server.js", "development"]
